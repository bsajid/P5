# Fichier .env — Variables d'authentification MongoDB
# Il est déjà listé dans .gitignore

# Utilisateur 1 : root_admin — superadmin, pour l'administration uniquement
MONGO_ROOT_USER=root_admin
MONGO_ROOT_PASS=RootPassword123!

# Utilisateur 2 : read_write_user — utilisé par le script de migration
# Droits : lire + écrire + créer des index dans medical_db uniquement
MONGO_RW_USER=read_write_user
MONGO_RW_PASS=ReadWritePassword456!

# Utilisateur 3 : read_only_user — pour consulter les données (ex: MongoDB Compass)
# Droits : lecture seule dans medical_db
MONGO_RO_USER=read_only_user
MONGO_RO_PASS=ReadOnlyPassword789!
